@model IEnumerable<SistemaPulperia.Models.ApplicationUser>
@{
    ViewData["Title"] = "Lista de Usuarios";
}

<style>
    /* Estilos de encabezado y botones circulares */
    table thead.thead-blue th {
        background-color: #0a2161 !important;
        color: #ffffff !important;
        font-weight: 800 !important;
        text-transform: uppercase;
        padding: 15px !important;
        border-bottom: 3px solid #d4af37 !important;
        text-align: center;
    }
    
    .action-buttons-container { display: flex; gap: 10px; justify-content: center; align-items: center; }

    .btn-action-circle {
        width: 38px; height: 38px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        background-color: transparent; border: 1.5px solid transparent; transition: all 0.3s ease;
    }

    .btn-edit-circle { border-color: #0d6efd; color: #0d6efd; }
    .btn-edit-circle:hover { background-color: #0d6efd; color: white; }
    .btn-key-circle { border-color: #ffc107; color: #ffc107; }
    .btn-key-circle:hover { background-color: #ffc107; color: white; }
    .btn-lock-circle { border-color: #6c757d; color: #6c757d; }
    .btn-lock-circle:hover { background-color: #6c757d; color: white; }
    .btn-delete-circle { border-color: #dc3545; color: #dc3545; }
    .btn-delete-circle:hover { background-color: #dc3545; color: white; }

    .requirement { font-size: 0.85rem; transition: all 0.3s ease; }
    .requirement.valid { color: #198754; text-decoration: line-through; opacity: 0.6; }
    .requirement.invalid { color: #dc3545; }
</style>

<div class="page-header d-flex justify-content-between align-items-center shadow mb-4">
    <div>
        <h2 class="fw-bold mb-0 text-white"><i class="bi bi-person-lines-fill me-2"></i> LISTA DE USUARIOS</h2>
        <small class="text-gold">Personal administrativo y de ventas</small>
    </div>
    <a asp-action="Registrar" class="btn btn-outline-light border-gold text-gold rounded-pill px-4 fw-bold">
        <i class="bi bi-person-plus-fill me-1"></i> NUEVO USUARIO
    </a>
</div>

<div class="container-fluid">
    <div class="table-container shadow-sm border-gold bg-white p-4" style="border-radius: 15px;">
        <table id="tblUsuarios" class="table table-hover w-100 align-middle text-center">
            <thead class="thead-blue">
                <tr>
                    <th>Nombre Completo</th>
                    <th>Usuario</th>
                    <th>Correo</th>
                    <th>Nivel de Acceso</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalResetPass" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-gold shadow">
            <div class="modal-header bg-dark" style="border-bottom: 3px solid #d4af37;">
                <h5 class="modal-title text-white fw-bold"><i class="bi bi-shield-lock text-gold me-2"></i> Nueva Contraseña</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formResetPass">
                    <input type="hidden" name="id" id="resetUsuarioId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Insertar Nueva Clave</label>
                        <div class="input-group">
                            <input type="password" id="new_pass" name="newPassword" class="form-control border-gold rounded-start-pill" required>
                            <button type="button" class="btn btn-outline-secondary border-gold rounded-end-pill" onclick="togglePassReset()">
                                <i class="bi bi-eye" id="eyeIconReset"></i>
                            </button>
                        </div>
                        <div id="reset-requirements" class="mt-3 p-3 bg-light rounded small border">
                            <h6 class="fw-bold mb-2 small text-uppercase text-muted">Requisitos:</h6>
                            <div id="r-length" class="requirement invalid mb-1"><i class="bi bi-circle me-2"></i>8+ caracteres</div>
                            <div id="r-upper" class="requirement invalid mb-1"><i class="bi bi-circle me-2"></i>Una mayúscula</div>
                            <div id="r-special" class="requirement invalid mb-1"><i class="bi bi-circle me-2"></i>Un carácter especial</div>
                        </div>
                    </div>
                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" id="btnConfirmReset" class="btn btn-dark border-gold text-gold rounded-pill px-4 fw-bold shadow" disabled>Actualizar Clave</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
        let tabla;
        let modalResetObj;

        $(document).ready(function () {
            modalResetObj = new bootstrap.Modal(document.getElementById('modalResetPass'));

            tabla = $('#tblUsuarios').DataTable({
                ajax: { url: '/Account/ListarUsuarios', dataSrc: 'data' },
                columns: [
                    { data: 'nombreCompleto' },
                    { data: 'userName' },
                    { data: 'email' },
                    { 
                        data: 'rol',
                        render: function(data) {
                            let clase = data === 'Administrador' ? 'bg-dark text-gold border border-gold' : 'bg-light text-dark';
                            return `<span class="badge ${clase} px-3 rounded-pill">${data}</span>`;
                        }
                    },
                    { 
                        data: 'bloqueado',
                        render: function(data) {
                            return data ? '<span class="badge bg-danger">Bloqueado</span>' : '<span class="badge bg-success">Activo</span>';
                        }
                    },
                    {
                        data: 'id',
                        render: function (data, type, row) {
                            return `
                                <div class="action-buttons-container">
                                    <button class="btn btn-action-circle btn-edit-circle" title="Editar" onclick="editar('${data}')"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-action-circle btn-key-circle" title="Reset Clave" onclick="resetPass('${data}')"><i class="bi bi-key"></i></button>
                                    <button class="btn btn-action-circle btn-lock-circle" title="${row.bloqueado ? 'Desbloquear' : 'Bloquear'}" onclick="bloquear('${data}')">
                                        <i class="bi ${row.bloqueado ? 'bi-unlock' : 'bi-lock'}"></i>
                                    </button>
                                    <button class="btn btn-action-circle btn-delete-circle" title="Eliminar" onclick="eliminar('${data}')"><i class="bi bi-trash"></i></button>
                                </div>`;
                        }
                    }
                ],
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' }
            });
        });

        // CORRECCIÓN: Función unificada para actualizar los requisitos visuales
        function updateRequirement(id, isValid) {
            const el = $(id);
            if(isValid) {
                el.removeClass('invalid text-danger').addClass('valid text-success opacity-60')
                  .find('i').removeClass('bi-circle').addClass('bi-check-circle-fill');
            } else {
                el.removeClass('valid text-success opacity-60').addClass('invalid text-danger')
                  .find('i').removeClass('bi-check-circle-fill').addClass('bi-circle');
            }
        }

        function resetPass(id) {
            $('#formResetPass')[0].reset();
            $('#resetUsuarioId').val(id);
            $('#btnConfirmReset').prop('disabled', true);
            
            // Reiniciar visualmente
            $('.requirement').removeClass('valid text-success opacity-60').addClass('invalid text-danger')
                             .find('i').removeClass('bi-check-circle-fill').addClass('bi-circle');
            
            modalResetObj.show();
        }

        $('#new_pass').on('input', function() {
            const val = $(this).val();
            const rules = {
                length: val.length >= 8,
                upper: /[A-Z]/.test(val),
                special: /[@@$!%*?&]/.test(val)
            };
            updateRequirement('#r-length', rules.length);
            updateRequirement('#r-upper', rules.upper);
            updateRequirement('#r-special', rules.special);
            $('#btnConfirmReset').prop('disabled', !Object.values(rules).every(Boolean));
        });

        $('#formResetPass').on('submit', function(e) {
            e.preventDefault();
            $.post('/Account/ResetPassword', $(this).serialize(), function(res) {
                if (res.success) {
                    Swal.fire('¡Éxito!', res.message, 'success');
                    modalResetObj.hide();
                    tabla.ajax.reload(null, false);
                } else {
                    Swal.fire('Seguridad', res.message, 'warning');
                }
            });
        });

        function bloquear(id) {
            $.post('/Account/ToggleBloqueo', { id: id }, function (res) {
                if (res.success) {
                    Swal.fire('Actualizado', res.message, 'success');
                    tabla.ajax.reload(null, false);
                }
            });
        }

        function eliminar(id) {
            Swal.fire({
                title: '¿Eliminar usuario?',
                text: "Esta acción no se puede deshacer.",
                icon: 'error',
                showCancelButton: true,
                confirmButtonText: 'Sí, eliminar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Account/EliminarUsuario', { id: id }, function (res) {
                        if (res.success) {
                            Swal.fire('Eliminado', res.message, 'success');
                            tabla.ajax.reload(null, false);
                        }
                    });
                }
            });
        }

        function togglePassReset() {
            const input = document.getElementById('new_pass');
            const icon = document.getElementById('eyeIconReset');
            input.type = input.type === "password" ? "text" : "password";
            icon.classList.toggle('bi-eye'); icon.classList.toggle('bi-eye-slash');
        }
    </script>
}